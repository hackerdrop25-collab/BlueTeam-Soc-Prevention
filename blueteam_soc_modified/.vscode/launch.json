{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🛡️ Dashboard (Flask)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["dashboard"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": { "FLASK_ENV": "development" }
    },
    {
      "name": "⚔️ Simulate: Full Attack Chain",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["simulate", "--scenario", "full_chain", "--host", "WORKSTATION-01", "--user", "attacker"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "🔍 Monitor (Real-time)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["monitor", "--interval", "5"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "📊 Analyse Once",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["analyse"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "📄 Generate Report",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["report"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
